# Projet Supabase → Settings → API (mêmes valeurs en local et sur l’hébergeur, en variables d’environnement)
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Google Cloud → Clé API Maps JavaScript + Places.
# Web (Vercel): restriction « HTTP referrers ».
# Android / iOS (Capacitor WebView): crée des clés séparées restreintes à l’app (package + SHA-1 / bundle id).
VITE_GOOGLE_MAPS_API_KEY=
# Optionnel : si défini, utilisé à la place de VITE_GOOGLE_MAPS_API_KEY sur la plateforme native.
VITE_GOOGLE_MAPS_API_KEY_ANDROID=
VITE_GOOGLE_MAPS_API_KEY_IOS=

# OneSignal → App ID (public). La REST API Key reste en secret Edge Function.
VITE_ONESIGNAL_APP_ID=
# Optionnel : app / plateforme mobile distincte dans OneSignal (sinon = VITE_ONESIGNAL_APP_ID).
# SDK natif : package npm `onesignal-cordova-plugin` (recommandé par OneSignal pour Capacitor).
VITE_ONESIGNAL_APP_ID_NATIVE=
